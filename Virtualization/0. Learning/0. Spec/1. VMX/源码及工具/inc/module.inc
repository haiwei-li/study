%ifndef __MODULE_INC__
%define __MODULE_INC__


;---------------------------------------------------------------------------
; บ๊ MODULE_HEADER: ถจาๅฤฃฟ้อทฝแนน
; input:
;       $1 - ฤฃฟ้ size
; example:
;       MODULE_HEADER   1, (PROECTED_END - PROTECTED_BEGIN)
; explain:
;       ถจาๅ protected ฤฃฟ้อทฝแนนฃฌด๓ะกฮช ดำ PROTECTED_END - PROTECTED_BEGIN
;       ฮปำฺ disk ตฤษศว๘ 1 ษฯ
;----------------------------------------------------------------------------
%macro MODULE_HEADER    1
header_size:            DW      8h              ; MODULE_HEADER ฝแนน 6 bytes
sector_position:        DW      $1              ; ฤฃฟ้ิฺ disk ตฤษศว๘ฮปึร
module_size:            DD      $2              ; ฤฃฟ้ด๓ะก
%endmacro



%endif
